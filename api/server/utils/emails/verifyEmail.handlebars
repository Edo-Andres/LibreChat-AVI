  <body
    class='clean-body u_body'
    style='margin: 0;padding: 0;-webkit-text-size-adjust: 100%;background-color: #212121;color: #ffffff'
  >
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verificar Email</title>
    <style>
        /* Reset styles */
        body, html { margin: 0; padding: 0; width: 100%; height: 100%; font-family: 'Inter', Arial, sans-serif; background-color: #F3F4F6; }
        table { border-collapse: collapse; width: 100%; }
        
        /* Client-specific styles */
        .email-container { max-width: 600px; margin: 40px auto; background-color: #ffffff; border-radius: 16px; overflow: hidden; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06); }
        .header { background: linear-gradient(135deg, #064e3b 0%, #000000 100%); padding: 40px 20px; text-align: center; }
        .content { padding: 40px 40px; color: #374151; }
        .footer { background-color: #F9FAFB; padding: 20px; text-align: center; font-size: 12px; color: #9CA3AF; border-top: 1px solid #E5E7EB; }
        
        /* Typography */
        h1 { margin: 0 0 20px 0; color: #111827; font-size: 24px; font-weight: 700; line-height: 1.2; }
        p { margin: 0 0 24px 0; font-size: 16px; line-height: 1.6; color: #4B5563; }
        
        /* Button */
        .button { display: inline-block; background-color: #059669; color: #ffffff; padding: 14px 32px; text-decoration: none; border-radius: 8px; font-weight: 600; font-size: 16px; text-align: center; transition: background-color 0.3s; }
        .button:hover { background-color: #047857; }
        
        /* Utilities */
        .text-center { text-align: center; }
        .mb-4 { margin-bottom: 16px; }
        .text-sm { font-size: 14px; }
        .text-muted { color: #6B7280; }
        
        /* Responsive */
        @media only screen and (max-width: 600px) {
            .email-container { width: 100% !important; margin: 0 !important; border-radius: 0 !important; }
            .content { padding: 30px 20px !important; }
        }
    </style>
</head>
<body>
    <table role="presentation" cellpadding="0" cellspacing="0" width="100%" bgcolor="#F3F4F6">
        <tr>
            <td align="center" style="padding: 20px 0;">
                
                <!-- Email Container -->
                <table role="presentation" class="email-container" cellpadding="0" cellspacing="0" width="100%" style="max-width: 600px; background-color: #ffffff; margin: 0 auto; border-radius: 16px; overflow: hidden;">
                    
                    <!-- Header with Gradient -->
                    <tr>
                        <td class="header" style="background: linear-gradient(135deg, #064e3b 0%, #000000 100%); padding: 40px 20px; text-align: center;">
                            <!-- Header Text -->
                            <h2 style="color: #ffffff; font-family: 'Inter', sans-serif; font-size: 24px; font-weight: 700; margin: 0 0 8px 0; line-height: 1.2;">AVI te acompaña</h2>
                            <p style="color: #e5e7eb; font-family: 'Inter', sans-serif; font-size: 16px; font-weight: 300; margin: 0; line-height: 1.4;">Sé parte de una gran comunidad para el cuidado</p>
                        </td>
                    </tr>

                    <!-- Main Content -->
                    <tr>
                        <td class="content" style="padding: 40px 40px;">
                            <h1 style="color: #111827; font-family: 'Inter', sans-serif; font-size: 24px; font-weight: 700; margin-bottom: 20px;">¡Bienvenido a {{appName}}!</h1>
                            
                            <p style="color: #4B5563; font-family: 'Inter', sans-serif; font-size: 16px; line-height: 1.6; margin-bottom: 24px;">
                                Estimado {{name}},
                            </p>
                            
                            <p style="color: #4B5563; font-family: 'Inter', sans-serif; font-size: 16px; line-height: 1.6; margin-bottom: 32px;">
                                Gracias por registrarte en {{appName}}. Para completar tu registro y verificar tu dirección de correo electrónico, por favor haz clic en el botón de abajo:
                            </p>

                            <!-- CTA Button -->
                            <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
                                <tr>
                                    <td align="center" style="padding-bottom: 32px;">
                                        <a href="{{verificationLink}}" class="button" style="background-color: #059669; color: #ffffff; padding: 14px 32px; text-decoration: none; border-radius: 12px; font-weight: 600; font-size: 16px; display: inline-block; font-family: 'Inter', sans-serif;">
                                            Verificar Email
                                        </a>
                                    </td>
                                </tr>
                            </table>

                            <p style="color: #6B7280; font-family: 'Inter', sans-serif; font-size: 14px; line-height: 1.5; margin-top: 20px; border-top: 1px solid #E5E7EB; padding-top: 20px;">
                                Si no creaste una cuenta en {{appName}}, por favor ignora este correo electrónico.
                            </p>
                            
                            <p style="color: #4B5563; font-family: 'Inter', sans-serif; font-size: 16px; line-height: 1.6; margin-top: 24px;">
                                Saludos cordiales,<br>
                                El equipo de {{appName}}
                            </p>
                        </td>
                    </tr>

                    <!-- Footer -->
                    <tr>
                        <td class="footer" style="background-color: #F9FAFB; padding: 24px; text-align: center; border-top: 1px solid #E5E7EB;">
                            <p style="color: #9CA3AF; font-family: 'Inter', sans-serif; font-size: 12px; margin-bottom: 8px;">
                                © {{year}} {{appName}}. Todos los derechos reservados.
                            </p>
                        </td>
                    </tr>
                </table>
                
                <!-- Spacer -->
                <div style="height: 40px;"></div>
            </td>
        </tr>
    </table>
</body>
</html>